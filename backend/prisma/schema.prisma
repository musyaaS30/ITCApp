datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  email            String            @unique
  password         String
  role             String            @default("member") // "member" or "admin"
  createdAt        DateTime          @default(now())
  
  registration     ClubRegistration?
  attendances      Attendance[]

  @@map("users")
}

model ClubRegistration {
  id              Int      @id @default(autoincrement())
  userId          Int?     @unique
  fullName        String
  email           String   @unique
  className       String
  reasonJoin      String   @db.Text
  division        String
  divisionReason  String   @db.Text
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("club_registrations")
}

model Attendance {
  id         Int      @id @default(autoincrement())
  userId     Int
  attendedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendance")
}
